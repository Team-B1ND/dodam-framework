    "styled-components": ">=6",
    "zod": "^4.3.6",
    "react-native-worklets": "0.5.1",
    "react-native-vision-camera": "^4.7.3",
    "expo-location": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "expo-location": {
      "optional": true
    }
  }
