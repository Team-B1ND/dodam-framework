{
  "name": "@b1nd/dodam-design-system",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./animations": {
      "types": "./dist/animations/index.d.ts",
      "import": "./dist/animations/index.js"
    },
    "./colors": {
      "types": "./dist/colors/index.d.ts",
      "import": "./dist/colors/index.js"
    },
    "./colors/colors.css": "./dist/colors/colors.css",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./icons/illustration": {
      "types": "./dist/icons/illustration/index.d.ts",
      "import": "./dist/icons/illustration/index.js"
    },
    "./icons/mono": {
      "types": "./dist/icons/mono/index.d.ts",
      "import": "./dist/icons/mono/index.js"
    },
    "./shapes": {
      "types": "./dist/shapes/index.d.ts",
      "import": "./dist/shapes/index.js"
    },
    "./shapes/tokens.tailwind.css": "./dist/shapes/tokens.tailwind.css",
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    },
    "./themes/init": {
      "types": "./dist/themes/init-theme.iife.d.ts",
      "import": "./dist/themes/init-theme.iife.js"
    },
    "./themes/theme.tailwind.css": "./dist/themes/theme.tailwind.css",
    "./typography": {
      "types": "./dist/typography/index.d.ts",
      "import": "./dist/typography/index.js"
    },
    "./typography/tokens.tailwind.css": "./dist/typography/tokens.tailwind.css",
    "./breakpoints": {
      "types": "./dist/breakpoints/index.d.ts",
      "import": "./dist/breakpoints/index.js"
    },
    "./breakpoints/tokens.tailwind.css": "./dist/breakpoints/tokens.tailwind.css",
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "import": "./dist/styles/index.js"
    },
    "./navigations": {
      "types": "./dist/navigations/index.d.ts",
      "import": "./dist/navigations/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node ./scripts/copy-assets.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "framer-motion": "^11.0.0",
    "react": ">=19",
    "react-dom": ">=19",
    "zustand": "^5.0.10",
    "next": ">=16"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "framer-motion": "^11.0.0",
    "next": "^15.0.0",
    "tsc-alias": "^1.8.16",
    "zustand": "^5.0.10"
  }
