{
  "name": "@dds-web/typography",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.tailwind.css": "./dist/tokens.tailwind.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-assets.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1"
  }
}
