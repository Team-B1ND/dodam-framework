{
  "name": "dodam-framework",
  "private": false,
  "packageManager": "pnpm@9.15.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/react": ">=19",
    "@types/react-dom": ">=19",
    "react": ">=19",
    "react-dom": ">=19",
    "turbo": "^2.7.3",
    "typescript": "^5.7.3",
    "vite": "^7.3.1"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0"
    }
  }
}
